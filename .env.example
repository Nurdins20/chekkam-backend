# Copy this file to .env.local and fill in real values.
# Nothing in this file should ever be committed with real secrets.
#
# Nothing here is required just to start the app — every integration below
# degrades gracefully when its variables are unset (see the comment on each
# section). The core loop (document sign/verify via web + Flutter app, and
# rule-based risk checking) works with only the Supabase block filled in.

# ============================================================================
# Supabase — required for almost everything (auth, database, storage)
# ============================================================================
# Project Settings -> API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: server-only, bypasses RLS. Never expose to any client.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# App base URL — used to build QR verification links and the Telegram webhook URL
# ============================================================================
APP_BASE_URL=http://localhost:3000

# ============================================================================
# AI risk analysis (SRS Section 8) — optional
# ============================================================================
# Without this, every channel (app, web, WhatsApp, Telegram, extension,
# partner API) still returns a result — they fall back to the deterministic
# rule-based analyzer (FR-025). Set it to get real AI-generated reasoning.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# Document signing (SRS Section 10) — required for the sign/verify demo loop
# ============================================================================
# One ECDSA (P-256) private key per institution. Generate with:
#   npm run generate-signing-key            (standalone key pair)
#   npm run seed-demo                       (prints one for the demo institution)
# Set DOCUMENT_SIGNING_KEY_<INSTITUTION_ID> (uuid, dashes -> underscores,
# uppercased) to the printed PEM, with real newlines replaced by literal \n.
# Example: DOCUMENT_SIGNING_KEY_A1B2C3D4_...=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# ============================================================================
# Push notifications (SRS Section 2.4) — optional
# ============================================================================
# Firebase service-account JSON, minified to one line, as a single env var.
# Without this, push sends are skipped (logged, not sent) — nothing breaks.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ============================================================================
# WhatsApp bot (Phase 2 Section 4) — optional; without these the WhatsApp
# webhook still exists and won't crash, it just has no token to reply with.
# ============================================================================
# Permanent or system-user token from the Meta developer app.
WHATSAPP_CLOUD_API_TOKEN=
# The sending number's phone_number_id (Meta Business dashboard).
WHATSAPP_PHONE_NUMBER_ID=
# Your own chosen string — must match what you enter in the Meta webhook config.
WHATSAPP_VERIFY_TOKEN=
# Meta app secret, used to validate the X-Hub-Signature-256 header. Without
# this set, incoming webhook requests are NOT signature-checked (a warning is
# logged) — set this before going live.
WHATSAPP_APP_SECRET=

# ============================================================================
# Telegram bot (Phase 2 Section 5) — optional; without these the Telegram
# webhook still exists and won't crash, it just has no token to reply with.
# ============================================================================
# From @BotFather after creating the bot.
TELEGRAM_BOT_TOKEN=
# Your own chosen string — set via `npm run set-telegram-webhook`, then
# Telegram sends it back on every request for you to validate.
TELEGRAM_WEBHOOK_SECRET=

# ============================================================================
# Browser extension rate limiting (Phase 2 Section 6.1) — optional
# ============================================================================
# Create a free database at upstash.com for cross-instance rate limiting.
# Without these, /api/extension/check falls back to an in-memory limiter
# (fine for local dev/demo; per-process only in a multi-instance deployment).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================================
# Privacy (Phase 2 Section 13, Law 2024/017) — set before any real channel traffic
# ============================================================================
# Salt used to hash phone numbers / chat IDs at rest (channel_identities'
# raw external_id is the one intentional exception — see migration 0002).
# Without this, a fallback dev-only salt is used — set a real random value
# before going live.
CHANNEL_ID_SALT=

# ============================================================================
# Seed script overrides (Phase 2 Section 8.1) — optional
# ============================================================================
# Which WhatsApp number / Telegram user ID `npm run seed-demo` links as a
# verified officer identity, so SIGN works immediately for your test account.
DEMO_WHATSAPP_NUMBER=237600000001
DEMO_TELEGRAM_ID=000000001
